      "parameters": {
        "promptType": "define",
        "text": "=Create a concise executive summary for emergency coordinators.\n\nIncident: {{ $('Set Incident Data').item.json.incident_description }} (ID: {{ $('Set Incident Data').item.json.incident_id }}, Location: {{ $('Set Incident Data').item.json.location }})\nDisaster Analysis: {{ JSON.stringify($('Incident Analyzer').item.json.output) }}\nWeather: {{ $('Weather Check').item.json.weather?.[0]?.main || 'Unknown' }}, {{ $('Weather Check').item.json.main?.temp || 'Unknown' }} C, wind {{ $('Weather Check').item.json.wind?.speed || 'Unknown' }} m/s\nRequired Resources: {{ JSON.stringify($json.output) }}",
        "options": {
          "systemMessage": "You are an emergency operations coordinator. Write a concise, well-structured executive summary for emergency coordinators that clearly covers: the Incident, Severity, Weather, Required Resources, Estimated Response Time, and Immediate Actions. Use short headed sections and plain professional language. Return plain text only."
