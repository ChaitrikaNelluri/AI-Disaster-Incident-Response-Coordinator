    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze the following disaster incident report.\n\nIncident ID: {{ $json.incident_id }}\nDescription: {{ $json.incident_description }}\nLocation: {{ $json.location }}\nReporter: {{ $json.reporter_name }}\nContact: {{ $json.contact_number }}\nDate & Time: {{ $json.date_time }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an emergency disaster response analyst.\n\nAnalyze the incident and return ONLY valid JSON with the following structure:\n\n{\n \"disaster_type\":\"\",\n \"severity\":\"\",\n \"priority\":\"\",\n \"people_at_risk\":\"\",\n \"recommended_teams\":[],\n \"recommended_vehicles\":[],\n \"estimated_response_time\":\"\",\n \"incident_summary\":\"\"\n}\n\nDo not return markdown or explanations."
        }
      },
      "id": "15c3838c-edd0-4329-9406-6d8b3738b416",
