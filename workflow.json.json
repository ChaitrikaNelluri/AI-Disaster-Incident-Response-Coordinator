        "text": "=Disaster Analysis (JSON):\n{{ JSON.stringify($('Incident Analyzer').item.json.output) }}\n\nWeather Conditions:\nWeather: {{ $('Weather Check').item.json.weather?.[0]?.main || 'Unknown' }}\nTemperature: {{ $('Weather Check').item.json.main?.temp || 'Unknown' }} C\nWind Speed: {{ $('Weather Check').item.json.wind?.speed || 'Unknown' }} m/s\nHumidity: {{ $('Weather Check').item.json.main?.humidity || 'Unknown' }} %",
        "hasOutputParser": true,
