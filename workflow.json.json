        "message": "=<h2>Disaster Incident Alert</h2><p><b>Incident ID:</b> {{ $('Set Incident Data').item.json.incident_id }}</p><p><b>Disaster Type:</b> {{ $('Incident Analyzer').item.json.output.disaster_type }}</p><p><b>Severity:</b> {{ $('Incident Analyzer').item.json.output.severity }}</p><p><b>Priority:</b> {{ $('Incident Analyzer').item.json.output.priority }}</p><p><b>Location:</b> {{ $('Set Incident Data').item.json.location }}</p><p><b>Weather:</b> {{ $('Weather Check').item.json.weather?.[0]?.main || 'Unknown' }}, {{ $('Weather Check').item.json.main?.temp || 'Unknown' }} C, wind {{ $('Weather Check').item.json.wind?.speed || 'Unknown' }} m/s, humidity {{ $('Weather Check').item.json.main?.humidity || 'Unknown' }} %</p><p><b>Recommended Resources:</b><br><pre>{{ JSON.stringify($('Resource Allocation').item.json.output, null, 2) }}</pre></p><h3>Executive Summary</h3><p>{{ $json.output }}</p>",
